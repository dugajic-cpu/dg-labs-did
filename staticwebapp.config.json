{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/invite.html",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin.html",
      "statusCode": 302
    }
  },
  "auth": {
    "rolesSource": "/api/get-roles",
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/ae9d2ba4-c305-4907-9fdb-17a023f7a5e8",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        }
      }
    }
  }
}
