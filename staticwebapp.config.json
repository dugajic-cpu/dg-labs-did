{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/invite.html",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/admin.html",
      "statusCode": 302
    }
  }
}
